:t afficher_avec_etoiles 

afficher_avec_etoiles 3.14
-- ***3.14***

afficher_avec_etoiles "Hello"
-- ***"hello"***

afficher_avec_etoiles [1,2,3]
-- ***[1,2,3]***


:t combine
combine (afficher_avec_etoiles 2) (afficher_avec_etoiles 3) 
-- ***2***
-- ***3***

combine (afficher_avec_etoiles "Hello") (afficher_avec_etoiles "World")
-- ***"Hello"***
-- ***"World"***


